        contactsUpdates: 'Contacts & development updates',
        donations: 'Donations',
        supportDrawerTitle: 'Support my work',
        supportIntro: 'You can support my open-source development using one of the addresses below.',
        copy: 'Copy',
        copied: 'Copied',
        networkWarning: 'Please verify the selected asset and network before sending. Transfers made through an incompatible network may be lost.',
        close: 'Close',
        closeKernelDetails: 'Close Android development details',
        closeSupportDetails: 'Close support details',
        musicToggle: 'Toggle background music'
      },
      ru: {
        headline: 'Android-разработчик уровня Middle · Мейнтейнер · Системный разработчик · Kernel Hacker',
        shortBio: 'Я работаю на стыке программного обеспечения и железа: разрабатываю кастомные ядра и прошивки Android, занимаюсь bring-up устройств, настройкой ОС, оптимизацией производительности и низкоуровневой системной разработкой.',
        languages: 'Русский — родной · Английский — B2–C1 · Испанский — начальный',
        kernelButtonTitle: 'Ядра и прошивки Android',
        kernelButtonDescription: 'Устройства, ROM, ядра и репозитории',
        supportButtonTitle: 'Поддержать мою работу',
        supportButtonDescription: 'GRAM, USDT и DonationAlerts',
        developmentHistory: 'История разработки',
        kernelDrawerTitle: 'Ядра Android и кастомные прошивки',
        profile: 'Обо мне',
        kernelProfile: 'Я разрабатываю и сопровождаю кастомные ядра Android и сборки прошивок, занимаюсь bring-up устройств, настройкой производительности и автономности, конфигурацией планировщика и памяти, а также низкоуровневыми исправлениями платформы. Я также создал KuroNekoDroid / KNXDroid — проект оптимизированной системы на базе Android, который сейчас неактивен из-за нехватки свободного времени.',
        kernelBringup: 'Bring-up ядра',
        customRoms: 'AOSP / кастомные ROM',
        performanceTuning: 'Настройка производительности',
        powerOptimization: 'Оптимизация энергопотребления',
        deviceMaintenance: 'Сопровождение устройств',
        activeDevelopment: 'Активная разработка',
        oneplus10Current: 'Основное устройство · crDroid Android 16',
        active: 'Активно',
        archivedDevices: 'Предыдущие / архивные устройства',
        iphoneScripts: 'Скрипты для деблоата и обслуживания',
        dropped: 'Закрыто',
        projectsRepositories: 'Проекты и репозитории',
        knxDescription: 'Кастомная система на базе Android и репозитории устройств',
        oneplus10KernelSource: 'Исходный код ядра для OnePlus 10 Pro',
        oneplus7KernelWork: 'Работа над ядром платформы OnePlus 7',
        realmeKernelSource: 'Исходный код ядра платформы Realme',
        mi9tKernelWork: 'Работа над ядром платформы Xiaomi Mi 9T',
        knxKernelRepository: 'Репозиторий ядра KNXDroid',
        kuronekoDescription: 'Разработка KuroNekoDroid для устройств на MediaTek MT6765',
        contactsUpdates: 'Контакты и новости разработки',
        donations: 'Поддержка',
        supportDrawerTitle: 'Поддержать мою работу',
        supportIntro: 'Вы можете поддержать мою open-source разработку, используя один из адресов ниже.',
        copy: 'Копировать',
        copied: 'Скопировано',
        networkWarning: 'Перед отправкой проверьте выбранный актив и сеть. Перевод через несовместимую сеть может быть потерян.',
        close: 'Закрыть',
        closeKernelDetails: 'Закрыть информацию об Android-разработке',
        closeSupportDetails: 'Закрыть информацию о поддержке',
        musicToggle: 'Переключить фоновую музыку'
      }
    };

    const browserLanguage = navigator.languages?.[0] || navigator.language || 'en';
    const currentLanguage: Language = browserLanguage.toLowerCase().startsWith('ru') ? 'ru' : 'en';

    function applyTranslations(language: Language) {
      document.documentElement.lang = language;

      document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((element) => {
        const key = element.dataset.i18n;
        if (key && translations[language][key]) {
          element.textContent = translations[language][key];
        }
      });

      document.querySelectorAll<HTMLElement>('[data-i18n-aria-label]').forEach((element) => {
        const key = element.dataset.i18nAriaLabel;
        if (key && translations[language][key]) {
          element.setAttribute('aria-label', translations[language][key]);
        }
      });
    }

    applyTranslations(currentLanguage);

    interface DrawerElements {
      root: HTMLElement;
      panel: HTMLElement;
      backdrop: HTMLElement;
      openButton: HTMLButtonElement;
      closeButton: HTMLButtonElement;
    }

    let activeDrawer: DrawerElements | null = null;

    function createDrawer(prefix: string): DrawerElements | null {
      const root = document.getElementById(`${prefix}-drawer`);
      const panel = document.getElementById(`${prefix}-drawer-panel`);
      const backdrop = document.getElementById(`${prefix}-drawer-backdrop`);
      const openButton = document.getElementById(`${prefix}-drawer-open`);
      const closeButton = document.getElementById(`${prefix}-drawer-close`);

      if (
        !(root instanceof HTMLElement) ||
        !(panel instanceof HTMLElement) ||
        !(backdrop instanceof HTMLElement) ||
        !(openButton instanceof HTMLButtonElement) ||
        !(closeButton instanceof HTMLButtonElement)
      ) {
        return null;
      }

      const drawer: DrawerElements = { root, panel, backdrop, openButton, closeButton };

      const open = () => {
        if (activeDrawer && activeDrawer !== drawer) {
          closeDrawer(activeDrawer, false);
        }

        root.classList.remove('pointer-events-none');
        root.setAttribute('aria-hidden', 'false');
        openButton.setAttribute('aria-expanded', 'true');
        activeDrawer = drawer;

        requestAnimationFrame(() => {
          panel.classList.remove('translate-y-full');
          backdrop.classList.remove('bg-black/0', 'backdrop-blur-none');
          backdrop.classList.add('bg-black/70', 'backdrop-blur-sm');
        });

        window.setTimeout(() => closeButton.focus(), 300);
      };

      openButton.addEventListener('click', open);
      closeButton.addEventListener('click', () => closeDrawer(drawer));
      backdrop.addEventListener('click', () => closeDrawer(drawer));

      return drawer;
    }

    function closeDrawer(drawer: DrawerElements, restoreFocus = true) {
      drawer.panel.classList.add('translate-y-full');
      drawer.backdrop.classList.remove('bg-black/70', 'backdrop-blur-sm');
      drawer.backdrop.classList.add('bg-black/0', 'backdrop-blur-none');
      drawer.root.setAttribute('aria-hidden', 'true');
      drawer.openButton.setAttribute('aria-expanded', 'false');

      if (activeDrawer === drawer) {
        activeDrawer = null;
      }

      window.setTimeout(() => {
        drawer.root.classList.add('pointer-events-none');
        if (restoreFocus) drawer.openButton.focus();
      }, 500);
    }

    createDrawer('kernel');
    createDrawer('support');

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && activeDrawer) {
        closeDrawer(activeDrawer);
      }
    });

    document.querySelectorAll<HTMLButtonElement>('.copy-wallet').forEach((button) => {
      button.addEventListener('click', async () => {
        const value = button.dataset.copyValue;
        if (!value) return;

        try {
          await navigator.clipboard.writeText(value);
          button.textContent = translations[currentLanguage].copied;
          window.setTimeout(() => {
            button.textContent = translations[currentLanguage].copy;
          }, 1400);
        } catch (error) {
          console.error('Unable to copy wallet address:', error);
        }
      });
    });

    window.addEventListener('load', () => {
      window.setTimeout(() => {
        const video = document.getElementById('bg-video') as HTMLVideoElement | null;
        const audio = document.getElementById('bg-audio') as HTMLAudioElement | null;
        const toggleButton = document.getElementById('music-toggle-btn') as HTMLButtonElement | null;
        const mutePath = document.getElementById('mute-path');
        const unmutePath = document.getElementById('unmute-path');

        function setIconState(isPlaying: boolean) {
          if (isPlaying) {
            mutePath?.classList.add('hidden');
            unmutePath?.classList.remove('hidden');
          } else {
            mutePath?.classList.remove('hidden');
            unmutePath?.classList.add('hidden');
          }
        }

        if (video) {
          video.classList.remove('opacity-0');
          video.play().catch((error) => console.error('Video playback error:', error));
        }

        toggleButton?.classList.remove('opacity-0');
        setIconState(false);

        if (toggleButton && audio) {
          toggleButton.addEventListener('click', () => {
            if (audio.paused) {
              audio.volume = 0;
              audio.play().then(() => {
                fadeInAudio(audio, 0.4, 1000);
                setIconState(true);
              }).catch((error) => console.error('Audio playback error:', error));
            } else {
              audio.pause();
              setIconState(false);
            }
          });
        }
      }, 2000);
    });

    function fadeInAudio(audio: HTMLAudioElement, targetVolume: number, duration: number) {
      const steps = 20;
      const stepTime = duration / steps;
      const volumeStep = targetVolume / steps;
      let currentVolume = 0;

      const interval = window.setInterval(() => {
        currentVolume += volumeStep;

        if (currentVolume >= targetVolume) {
          audio.volume = targetVolume;
          window.clearInterval(interval);
        } else {
          audio.volume = currentVolume;
        }
      }, stepTime);
    }
  </script>
